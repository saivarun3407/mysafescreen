---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found | SafeScreen" description="That page doesn't exist.">
  <section class="container-tight flex min-h-[60vh] flex-col items-start justify-center">
    <p class="mono text-sm text-accent">404</p>
    <h1 class="mt-4 text-3xl sm:text-4xl">This page slipped off the screen.</h1>
    <p class="mt-3 text-fg-2">The link may be broken, or the page may have moved.</p>
    <a href="/" class="btn btn-primary mt-8">Back home</a>
  </section>
</Layout>
