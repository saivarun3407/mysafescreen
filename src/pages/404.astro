---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — SafeScreen" description="That page doesn't exist.">
  <section class="mx-auto flex min-h-[70vh] max-w-xl flex-col items-center justify-center px-5 text-center sm:px-8">
    <div class="font-display text-7xl font-700 text-gradient">404</div>
    <h1 class="mt-4 text-2xl font-700">This page slipped off the screen.</h1>
    <p class="mt-3 text-mist-400">The link may be broken or the page may have moved.</p>
    <a href="/" class="btn-primary mt-8 rounded-full px-6 py-3 text-sm">Back to safety</a>
  </section>
</Layout>
