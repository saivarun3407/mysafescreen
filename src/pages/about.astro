---
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const values = [
  { title: 'Protect the most targeted', body: 'Image-based abuse falls hardest on kids, teens, and women. We build for them first — the people with the most to lose and the least recourse.' },
  { title: 'Privacy is non-negotiable', body: 'A safety tool that harvests your data is not a safety tool. Everything runs on your device, with nothing to upload and nothing to leak.' },
  { title: 'Honesty over hype', body: 'We tell you what works, what doesn’t yet, and where the edges are. Confidence you can verify beats claims you have to believe.' },
];
---

<Layout
  title="About SafeScreen"
  description="SafeScreen began with people we know being harmed by deepfakes and online abuse. Our mission: put the safety check on the device, in real time, for the people most targeted."
>
  <section class="container-tight pt-20 pb-4 sm:pt-28">
    <p class="eyebrow">Our mission</p>
    <h1 class="mt-5 max-w-3xl text-[2.4rem] leading-[1.06] sm:text-5xl">
      A safety layer for the people most targeted.
    </h1>
  </section>

  <!-- story -->
  <section class="container-tight mt-12">
    <div class="max-w-2xl space-y-6 text-lg leading-relaxed text-fg-2">
      <p>
        Someone close to us was targeted by a deepfake. A friend's younger sister was harassed with images
        online. Each time, the pattern repeated: by the time anyone could react, the harmful content had
        already been seen, screenshotted, forwarded, and amplified.
      </p>
      <p>
        The tools meant to stop this all lived in the cloud — reactive, after-the-fact, and built around a
        quiet absurdity: to ask "is this image safe?", a victim first has to upload their most private
        moment to someone else's server. The safeguard was its own kind of exposure.
      </p>
      <p class="text-fg">So we made a different bet: put the safety check at the edge. On the device, in real time, private by construction.</p>
      <p>
        SafeScreen started as a focused engineering build — proving two compact AI models could run fast
        enough, on a phone, to blur harmful content before you see it, without a single byte leaving the
        device. It worked. Now we're turning it into something everyone can put on their phone.
      </p>
    </div>
  </section>

  <!-- stat -->
  <section class="container-tight mt-24">
    <div class="border-t border-line-soft pt-10">
      <div class="mono text-5xl text-fg sm:text-6xl">~96%</div>
      <p class="mt-4 max-w-xl text-lg text-fg-2">
        of people targeted by deepfake abuse are women and girls. The technology that creates this harm is
        getting cheaper and faster. The defense has to live where the harm lands — on the screen, in the moment.
      </p>
    </div>
  </section>

  <!-- values -->
  <section class="container-tight mt-32">
    <p class="eyebrow">What we stand for</p>
    <h2 class="mt-5 text-3xl sm:text-4xl">Three commitments we won't trade away.</h2>
    <div class="mt-10 grid gap-px overflow-hidden rounded-xl border border-line bg-line md:grid-cols-3">
      {
        values.map((v, i) => (
          <div class="bg-surface p-7">
            <div class="mono text-sm text-accent">0{i + 1}</div>
            <h3 class="mt-4 text-xl">{v.title}</h3>
            <p class="mt-3 leading-relaxed text-fg-2">{v.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- vision -->
  <section class="container-tight mt-24">
    <div class="max-w-2xl border-l border-accent/50 pl-6">
      <p class="text-2xl leading-snug text-fg sm:text-3xl">
        A private, real-time safety layer for everyone — starting with the people who need it most.
      </p>
      <p class="mt-4 text-fg-3">Next on the roadmap: faster on-device acceleration, region-precise blur, and text-based protection.</p>
    </div>
  </section>

  <!-- CTA -->
  <section id="waitlist" class="container-tight mt-32">
    <div class="card flex flex-col items-start gap-7 p-10 sm:p-14">
      <h2 class="text-3xl sm:text-4xl">Help us protect more screens.</h2>
      <WaitlistForm />
    </div>
  </section>
</Layout>
