---
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const guarantees = [
  { title: 'No internet permission', body: 'The app requests no network access at all. An app that cannot reach the internet cannot leak your screen. You can verify it in your phone’s settings.' },
  { title: 'It works in airplane mode', body: 'Turn off every radio and SafeScreen keeps protecting you. That’s the proof nothing it does depends on a server.' },
  { title: 'No accounts, ever', body: 'Nothing to sign up for. No email, no profile, no login. There’s no account database to breach because there are no accounts.' },
  { title: 'No tracking or analytics', body: 'No usage data, no telemetry, no crash pings tied to you. What happens on your phone stays on your phone.' },
];

const compare = [
  { dim: 'Where images are judged', cloud: 'Uploaded to a server', safe: 'On your device' },
  { dim: 'What detection requires', cloud: 'Receiving your images', safe: 'Never receiving them' },
  { dim: 'Works offline', cloud: 'No', safe: 'Yes' },
  { dim: 'Account required', cloud: 'Usually', safe: 'Never' },
  { dim: 'Data that can leak', cloud: 'Whatever was uploaded', safe: 'Nothing leaves' },
];

const never = [
  'Upload your screen or images',
  'Create an account or profile of you',
  'Track what you look at',
  'Report you to anyone',
  'Delete or alter your content',
  'Need a network connection to work',
];
---

<Layout
  title="Privacy and security | nothing leaves your device"
  description="SafeScreen ships with no internet permission, works in airplane mode, and requires no account. The AI runs entirely on your phone."
>
  <section class="container-tight pt-20 pb-4 sm:pt-28">
    <p class="eyebrow">Privacy &amp; security</p>
    <h1 class="mt-5 max-w-3xl text-[2.4rem] leading-[1.06] sm:text-5xl">
      Your screen never leaves your phone.
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-fg-2">
      Most "safe" apps ask you to trust a privacy policy. SafeScreen removes the need for trust entirely:
      it's built so that sending your data away is not even possible.
    </p>
  </section>

  <!-- guarantees -->
  <section class="container-tight mt-16">
    <div class="grid gap-px overflow-hidden rounded-xl border border-line bg-line sm:grid-cols-2">
      {
        guarantees.map((g) => (
          <div class="bg-surface p-7">
            <h3 class="text-lg">{g.title}</h3>
            <p class="mt-2 leading-relaxed text-fg-2">{g.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- the argument -->
  <section class="container-tight mt-32">
    <div class="max-w-2xl">
      <p class="eyebrow">The core idea</p>
      <h2 class="mt-5 text-3xl sm:text-4xl">To judge your most private images, a cloud must first receive them.</h2>
      <p class="mt-6 text-lg leading-relaxed text-fg-2">
        That's the contradiction at the heart of cloud-based safety. The only way for a server to check
        whether an image is explicit, or a deepfake of you, is to take a copy of it. The protection
        becomes the exposure. SafeScreen resolves it by never moving the image at all.
      </p>
    </div>
  </section>

  <!-- comparison -->
  <section class="container-tight mt-24">
    <p class="eyebrow">Cloud filter vs. SafeScreen</p>
    <div class="mt-8 overflow-hidden rounded-xl border border-line">
      <div class="grid grid-cols-[1.4fr_1fr_1fr] border-b border-line text-sm">
        <div class="px-5 py-3.5"></div>
        <div class="px-5 py-3.5 text-fg-3">Cloud filter</div>
        <div class="px-5 py-3.5 font-600 text-accent">SafeScreen</div>
      </div>
      {
        compare.map((row, i) => (
          <div class:list={['grid grid-cols-[1.4fr_1fr_1fr] text-sm', i > 0 && 'border-t border-line-soft']}>
            <div class="px-5 py-4 text-fg">{row.dim}</div>
            <div class="px-5 py-4 text-fg-3">{row.cloud}</div>
            <div class="px-5 py-4 text-fg">{row.safe}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- what we never do -->
  <section class="container-tight mt-32">
    <p class="eyebrow">What SafeScreen never does</p>
    <div class="mt-8 grid gap-px overflow-hidden rounded-xl border border-line bg-line sm:grid-cols-2">
      {
        never.map((item) => (
          <div class="flex items-center gap-3 bg-surface px-5 py-4">
            <svg viewBox="0 0 20 20" class="h-4 w-4 shrink-0 text-warn" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M5 5l10 10M15 5 5 15" stroke-linecap="round" />
            </svg>
            <span class="text-fg-2">{item}</span>
          </div>
        ))
      }
    </div>
    <p class="mt-6 text-fg-3">SafeScreen blurs and warns. The choice to reveal anything is always, only, yours.</p>
  </section>

  <!-- CTA -->
  <section id="waitlist" class="container-tight mt-32">
    <div class="card flex flex-col items-start gap-7 p-10 sm:p-14">
      <h2 class="text-3xl sm:text-4xl">Privacy you don't have to take on faith.</h2>
      <WaitlistForm />
    </div>
  </section>
</Layout>
