---
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const pipeline = [
  {
    n: '01',
    title: 'Capture the screen',
    body: 'A background service mirrors what is on your screen, frame by frame, in any app — the same secure mechanism your phone already uses for screen recording, kept entirely on-device.',
  },
  {
    n: '02',
    title: 'A fast first pass, every frame',
    body: 'A compact image classifier (~10MB) checks every frame for explicit content, paired with a skin-tone backstop so two weak signals make one robust decision. Cheap enough to run continuously.',
  },
  {
    n: '03',
    title: 'A deeper check, only when needed',
    body: 'When something looks like an AI-generated face, a second model takes a closer look — only on candidate frames, never every frame, so the expensive check never slows things down.',
  },
  {
    n: '04',
    title: 'Decide, then intervene',
    body: 'A policy engine combines the signals, smooths them over time, and decides: clear, warn, or blur. If it blurs, you see a label and tap to reveal. You stay in control.',
  },
];

const specs = [
  { label: 'Total model size', value: '~26 MB' },
  { label: 'Per-frame latency', value: '<26 ms' },
  { label: 'Network calls', value: '0' },
  { label: 'Runtime', value: 'On-device' },
];
---

<Layout
  title="How SafeScreen works"
  description="How SafeScreen detects and blurs harmful and AI-faked imagery in real time, entirely on your device. Two compact models, a fast cascade, zero cloud."
>
  <section class="container-tight pt-20 pb-4 sm:pt-28">
    <p class="eyebrow">How it works</p>
    <h1 class="mt-5 max-w-3xl text-[2.4rem] leading-[1.06] sm:text-5xl">
      Real-time AI safety, running entirely on your phone.
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-fg-2">
      No cloud, no accounts, no waiting on a server. Here's the path a single frame takes — from the moment
      it appears on your screen to the moment SafeScreen decides whether you should see it.
    </p>
  </section>

  <!-- pipeline -->
  <section class="container-tight mt-16">
    <div class="overflow-hidden rounded-xl border border-line">
      {
        pipeline.map((p, i) => (
          <div class:list={['grid gap-4 p-7 sm:grid-cols-[3rem_1fr] sm:gap-7', i > 0 && 'border-t border-line']}>
            <div class="mono text-sm text-accent">{p.n}</div>
            <div>
              <h3 class="text-xl">{p.title}</h3>
              <p class="mt-2 leading-relaxed text-fg-2">{p.body}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- specs -->
  <section class="container-tight mt-20">
    <div class="grid grid-cols-2 border-t border-line-soft sm:grid-cols-4">
      {
        specs.map((s) => (
          <div class="border-b border-line-soft px-2 py-7 sm:border-b-0 sm:border-l sm:first:border-l-0 sm:pl-6">
            <div class="mono text-2xl text-fg">{s.value}</div>
            <div class="mt-1 text-sm text-fg-3">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- two detectors -->
  <section class="container-tight mt-32">
    <p class="eyebrow">Two jobs, two models</p>
    <h2 class="mt-5 text-3xl sm:text-4xl">What SafeScreen looks for.</h2>
    <div class="mt-10 grid gap-px overflow-hidden rounded-xl border border-line bg-line md:grid-cols-2">
      <div class="bg-surface p-8">
        <p class="mono text-xs text-accent">PRIMARY · EVERY FRAME</p>
        <h3 class="mt-4 text-2xl">Explicit imagery</h3>
        <p class="mt-3 leading-relaxed text-fg-2">
          A purpose-built classifier flags nudity and explicit content, reinforced by a skin-tone signal so
          it stays robust on real-world content. This is the workhorse — it runs continuously and drives the blur.
        </p>
      </div>
      <div class="bg-surface p-8">
        <p class="mono text-xs text-fg-3">SECONDARY · TRIGGERED</p>
        <h3 class="mt-4 text-2xl">AI-generated faces</h3>
        <p class="mt-3 leading-relaxed text-fg-2">
          A second model estimates whether a face was synthetically generated. This is genuinely hard, so
          SafeScreen surfaces it as a confidence badge — "possibly AI-generated" — never a verdict.
        </p>
      </div>
    </div>
  </section>

  <!-- honest limits -->
  <section class="container-tight mt-32">
    <div class="max-w-2xl">
      <p class="eyebrow">Where the limits are</p>
      <h2 class="mt-5 text-3xl sm:text-4xl">Said plainly.</h2>
      <ul class="mt-8 space-y-5 text-fg-2">
        <li class="border-l border-warn/50 pl-4">
          <strong class="font-600 text-fg">AI-image detection doesn't generalize perfectly.</strong> No on-device
          detector does today. We report it as a confidence signal and keep improving it — never certainty.
        </li>
        <li class="border-l border-warn/50 pl-4">
          <strong class="font-600 text-fg">It blurs the whole frame, not a region.</strong> Region-precise blur is
          on the roadmap.
        </li>
        <li class="border-l border-warn/50 pl-4">
          <strong class="font-600 text-fg">Today it focuses on images and video.</strong> Text moderation is a
          future addition, not part of v1.
        </li>
      </ul>
      <p class="mt-8 text-fg-3">
        <a href="/about" class="link-accent">Read why we built this →</a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section id="waitlist" class="container-tight mt-32">
    <div class="card flex flex-col items-start gap-7 p-10 sm:p-14">
      <h2 class="text-3xl sm:text-4xl">Want it on your phone?</h2>
      <WaitlistForm />
    </div>
  </section>
</Layout>
