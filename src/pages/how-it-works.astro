---
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const pipeline = [
  {
    n: '01',
    title: 'Capture the screen',
    body: 'A background service mirrors what is on your screen, frame by frame — in any app. This is the same secure capture mechanism your phone already uses for screen recording, kept entirely on-device.',
  },
  {
    n: '02',
    title: 'A fast first pass, every frame',
    body: 'A compact image classifier (MobileNet-class, ~10MB) checks every frame for explicit content. It is cheap enough to run continuously without draining your battery — paired with a classic skin-tone backstop so two weak signals make one robust decision.',
  },
  {
    n: '03',
    title: 'A deeper check, only when needed',
    body: 'When something looks like it might be an AI-generated face, a second model takes a closer look. It runs only on candidate frames — not every frame — so the expensive check never slows the experience down.',
  },
  {
    n: '04',
    title: 'Decide, then intervene',
    body: 'A policy engine combines the signals, smooths them over time to avoid flicker, and decides: clear, warn, or blur. If it blurs, you see a label and a "tap to reveal" — you are always in control.',
  },
];

const specs = [
  { label: 'Total model size', value: '~26 MB', note: 'Two models, bundled in the app' },
  { label: 'Per-frame latency', value: '< 26 ms', note: 'Measured on a Galaxy S25 Ultra' },
  { label: 'Network calls in the safety path', value: '0', note: 'There is no internet permission' },
  { label: 'Runtime', value: 'ExecuTorch', note: 'On-device, Snapdragon-accelerated' },
];
---

<Layout
  title="How SafeScreen works — on-device AI, explained"
  description="A clear look at how SafeScreen detects and blurs harmful and AI-faked imagery in real time, entirely on your device. Two compact models, a fast cascade, zero cloud."
>
  <section class="relative overflow-hidden pt-36 sm:pt-44">
    <div class="grid-lines pointer-events-none absolute inset-0 -z-10" aria-hidden="true"></div>
    <div class="mx-auto max-w-3xl px-5 text-center sm:px-8">
      <p class="reveal text-sm font-600 uppercase tracking-widest text-safe-400">How it works</p>
      <h1 class="reveal mt-4 font-display text-4xl font-700 leading-[1.08] sm:text-6xl">
        Real-time AI safety,<br /><span class="text-gradient">running entirely on your phone.</span>
      </h1>
      <p class="reveal mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-mist-300">
        No cloud. No accounts. No waiting on a server. Here's the path a single frame takes — from the
        moment it appears on your screen to the moment SafeScreen decides whether you should see it.
      </p>
    </div>
  </section>

  <!-- pipeline -->
  <section class="mx-auto mt-20 max-w-4xl px-5 sm:px-8">
    <div class="relative">
      <div class="absolute left-[1.85rem] top-2 bottom-2 w-px bg-gradient-to-b from-safe-400/40 via-white/10 to-transparent sm:left-[2.1rem]" aria-hidden="true"></div>
      <div class="space-y-5">
        {
          pipeline.map((p) => (
            <div class="reveal relative flex gap-5 sm:gap-7">
              <div class="ring-safe relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-ink-800 font-display text-sm font-700 text-safe-300 sm:h-[4.25rem] sm:w-[4.25rem] sm:text-lg">
                {p.n}
              </div>
              <div class="card card-hover flex-1 rounded-2xl p-6 sm:p-7">
                <h3 class="text-xl font-600">{p.title}</h3>
                <p class="mt-3 leading-relaxed text-mist-400">{p.body}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- the cascade insight -->
  <section class="mx-auto mt-28 max-w-6xl px-5 sm:px-8">
    <div class="card reveal rounded-[2rem] p-8 sm:p-12">
      <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <p class="text-sm font-600 uppercase tracking-widest text-safe-400">The core idea</p>
          <h2 class="mt-4 text-3xl font-700 sm:text-4xl">Cheap check often. Expensive check rarely.</h2>
          <p class="mt-5 leading-relaxed text-mist-300">
            Running a heavy AI model on every single frame would melt your battery and lag your phone. So
            SafeScreen uses a cascade: a light, fast model watches everything, and only escalates to the
            heavier model when something genuinely warrants a closer look.
          </p>
          <p class="mt-4 leading-relaxed text-mist-300">
            That's what makes continuous, real-time protection possible on a phone — not a data center.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3 self-center">
          {
            specs.map((s) => (
              <div class="glass rounded-2xl p-5">
                <div class="font-display text-2xl font-700 text-mist-100">{s.value}</div>
                <div class="mt-1 text-sm font-500 text-mist-200">{s.label}</div>
                <div class="mt-1 text-xs text-mist-500">{s.note}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- two detectors -->
  <section class="mx-auto mt-28 max-w-6xl px-5 sm:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-sm font-600 uppercase tracking-widest text-safe-400">Two jobs, two models</p>
      <h2 class="mt-4 text-3xl font-700 sm:text-4xl">What SafeScreen looks for.</h2>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-2">
      <div class="card card-hover reveal rounded-2xl p-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-safe-500/15 px-3 py-1 text-xs font-600 text-safe-300">Primary · every frame</div>
        <h3 class="mt-4 text-2xl font-700">Explicit imagery</h3>
        <p class="mt-3 leading-relaxed text-mist-400">
          A purpose-built classifier flags nudity and explicit content, reinforced by a skin-tone signal so
          it stays robust on real-world content. This is the workhorse — it runs continuously and drives the blur.
        </p>
      </div>
      <div class="card card-hover reveal rounded-2xl p-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-aqua-500/15 px-3 py-1 text-xs font-600 text-aqua-400">Secondary · triggered</div>
        <h3 class="mt-4 text-2xl font-700">AI-generated faces</h3>
        <p class="mt-3 leading-relaxed text-mist-400">
          A second model estimates whether a face was synthetically generated. AI-image detection is genuinely
          hard, so SafeScreen surfaces this as a confidence badge — "possibly AI-generated" — never a verdict.
        </p>
      </div>
    </div>
  </section>

  <!-- honest limits -->
  <section class="mx-auto mt-28 max-w-4xl px-5 sm:px-8">
    <div class="card reveal rounded-2xl border-l-2 border-l-warn-400/50 p-8">
      <h2 class="text-2xl font-700">Where the limits are — said plainly.</h2>
      <ul class="mt-5 space-y-4 text-mist-300">
        <li class="flex gap-3">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-warn-400"></span>
          <span><strong class="font-600 text-mist-100">AI-image detection doesn't generalize perfectly.</strong> No on-device detector does today. We report it as a confidence signal and keep improving it — we never claim certainty.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-warn-400"></span>
          <span><strong class="font-600 text-mist-100">It blurs the whole frame, not a region.</strong> When content is flagged, the screen blurs — precise region-level blur is on the roadmap.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-warn-400"></span>
          <span><strong class="font-600 text-mist-100">Today it focuses on images and video.</strong> Text moderation is a future addition, not part of v1.</span>
        </li>
      </ul>
      <p class="mt-6 text-sm text-mist-400">
        We believe an honest safety tool is the only kind worth trusting. <a href="/about" class="text-safe-300 underline-offset-4 hover:underline">Read why we built this →</a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section id="waitlist" class="mx-auto mt-28 max-w-3xl px-5 text-center sm:px-8">
    <h2 class="reveal text-3xl font-700 sm:text-4xl">Want it on your phone?</h2>
    <p class="reveal mx-auto mt-4 max-w-lg text-lg text-mist-300">Join the waitlist — one email when we launch.</p>
    <div class="reveal mt-8"><WaitlistForm /></div>
  </section>
</Layout>
