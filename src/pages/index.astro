---
import Layout from '../layouts/Layout.astro';
import PhoneMock from '../components/PhoneMock.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const stats = [
  { value: '0', label: 'bytes leave your phone' },
  { value: '<26ms', label: 'to scan a frame' },
  { value: '100%', label: 'on-device AI' },
  { value: 'Any', label: 'app, system-wide' },
];

const steps = [
  {
    n: '01',
    title: 'It watches your screen',
    body: 'A lightweight background service sees what you see, in any app, the moment it appears. No per-app setup.',
  },
  {
    n: '02',
    title: 'AI judges it on your phone',
    body: 'Two compact models — one for explicit imagery, one for AI-generated faces — run right on your device. No cloud.',
  },
  {
    n: '03',
    title: 'It blurs before you see it',
    body: 'Harmful content is blurred and labelled before it reaches your eyes. You decide whether to reveal it.',
  },
];

const guarantees = [
  'No internet permission',
  'Works in airplane mode',
  'No accounts, no sign-up',
  'No tracking, no telemetry',
];
---

<Layout>
  <!-- HERO -->
  <section class="container-tight pt-20 pb-8 sm:pt-28">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <p class="eyebrow">On-device · nothing leaves your phone</p>
        <h1 class="mt-5 text-[2.5rem] leading-[1.05] sm:text-[3.4rem]">
          Harmful content, blurred before you see it.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-fg-2">
          SafeScreen is a safety layer for your phone. It spots explicit and AI-faked imagery in real
          time — in any app — and blurs it before it reaches your eyes. Every check runs on your device.
          Nothing is ever uploaded.
        </p>

        <div class="mt-8">
          <WaitlistForm />
        </div>

        <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-fg-3">
          {
            guarantees.slice(0, 3).map((g) => (
              <span class="inline-flex items-center gap-2">
                <span class="h-1 w-1 rounded-full bg-accent" />
                {g}
              </span>
            ))
          }
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <PhoneMock />
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="container-tight pt-12">
    <div class="grid grid-cols-2 border-t border-line-soft sm:grid-cols-4">
      {
        stats.map((s) => (
          <div class="border-b border-line-soft px-2 py-7 sm:border-b-0 sm:border-l sm:first:border-l-0 sm:pl-6">
            <div class="mono text-2xl text-fg sm:text-[1.6rem]">{s.value}</div>
            <div class="mt-1 text-sm text-fg-3">{s.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="container-tight mt-32">
    <div class="max-w-2xl">
      <p class="eyebrow">The problem</p>
      <h2 class="mt-5 text-3xl sm:text-4xl">By the time anyone reacts, the damage is done.</h2>
      <p class="mt-6 text-lg leading-relaxed text-fg-2">
        Explicit and AI-faked images spread faster than any moderation team can keep up with. And today's
        filters live in the cloud — so to check whether an image is harmful, your most private moments
        have to be uploaded to someone else's server first. That upload is itself the harm.
      </p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="container-tight mt-32">
    <p class="eyebrow">How it works</p>
    <h2 class="mt-5 max-w-xl text-3xl sm:text-4xl">Three steps. All of them on your phone.</h2>

    <div class="mt-12 grid gap-px overflow-hidden rounded-xl border border-line bg-line md:grid-cols-3">
      {
        steps.map((step) => (
          <div class="bg-surface p-7">
            <div class="mono text-sm text-accent">{step.n}</div>
            <h3 class="mt-4 text-xl">{step.title}</h3>
            <p class="mt-3 leading-relaxed text-fg-2">{step.body}</p>
          </div>
        ))
      }
    </div>

    <a href="/how-it-works" class="link-accent mt-8 inline-block text-sm">Read the full breakdown →</a>
  </section>

  <!-- PRIVATE BY CONSTRUCTION -->
  <section class="container-tight mt-32">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <p class="eyebrow">The difference</p>
        <h2 class="mt-5 text-3xl sm:text-4xl">The app you can't put in the cloud.</h2>
        <p class="mt-6 text-lg leading-relaxed text-fg-2">
          To check whether an image is explicit — or a deepfake of you — a cloud service would have to
          receive your most private images first. SafeScreen never does. The AI runs entirely on your
          phone, so the judgement happens where the image already is.
        </p>
        <a href="/privacy" class="link-accent mt-6 inline-block text-sm">How we prove it →</a>
      </div>

      <ul class="grid content-start gap-px self-start overflow-hidden rounded-xl border border-line bg-line">
        {
          guarantees.map((g) => (
            <li class="flex items-center gap-3 bg-surface px-5 py-4">
              <svg viewBox="0 0 20 20" class="h-4 w-4 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="m4 10.5 3.5 3.5L16 6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="text-fg">{g}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- HONEST -->
  <section class="container-tight mt-32">
    <div class="max-w-2xl">
      <p class="eyebrow">Honest by design</p>
      <h2 class="mt-5 text-3xl sm:text-4xl">A safety tool you can actually trust.</h2>
      <p class="mt-6 text-lg leading-relaxed text-fg-2">
        SafeScreen blurs and warns — it never deletes, reports, or phones home. AI-image detection is
        hard, so we show it as a confidence signal, never a verdict. And because there's no internet
        permission, sending your data away isn't even possible.
      </p>
    </div>
  </section>

  <!-- WAITLIST CTA -->
  <section id="waitlist" class="container-tight mt-32">
    <div class="card flex flex-col items-start gap-8 p-10 sm:p-14">
      <div>
        <h2 class="text-3xl sm:text-4xl">Be first to protect your screen.</h2>
        <p class="mt-4 max-w-xl text-lg text-fg-2">
          SafeScreen is launching soon. Join the waitlist and we'll send you a single email the moment it's
          ready.
        </p>
      </div>
      <WaitlistForm />
    </div>
  </section>
</Layout>
