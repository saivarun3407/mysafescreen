---
import Layout from '../layouts/Layout.astro';
import PhoneMock from '../components/PhoneMock.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const steps = [
  { n: '01', body: 'Install SafeScreen.' },
  { n: '02', body: 'Turn on protection.' },
  { n: '03', body: 'Harmful images blur before you see them.' },
];

const useCases = [
  {
    role: 'Parents',
    body: 'Kids run into explicit content online. SafeScreen blurs it across every app they open, with no per-app setup.',
  },
  {
    role: 'Anyone targeted',
    body: 'Deepfakes and leaked images spread in seconds. SafeScreen helps flag possible AI-faked images before they reach you.',
  },
  {
    role: 'Privacy-first',
    body: 'You don’t trust apps that upload your screen. SafeScreen runs entirely on your phone. Nothing ever leaves the device.',
  },
];
---

<Layout>
  <!-- HERO -->
  <section class="container-tight pt-20 pb-8 sm:pt-28">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <h1 class="text-[2.6rem] leading-[1.04] sm:text-[3.5rem]">
          Harmful images, blurred before you see them.
        </h1>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-fg-2">
          SafeScreen catches explicit and AI-faked images in real time, on your phone. No cloud, no uploads.
        </p>

        <div class="mt-8">
          <WaitlistForm />
        </div>

        <div class="mt-6 space-y-1.5 text-sm text-fg-3">
          <p class="flex items-center gap-2">
            <span class="h-1 w-1 rounded-full bg-accent"></span>
            No internet permission. You can verify it in the app.
          </p>
          <p class="flex items-center gap-2">
            <span class="h-1 w-1 rounded-full bg-accent"></span>
            Android today. iOS coming later.
          </p>
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <PhoneMock />
      </div>
    </div>
  </section>

  <!-- DEMO (placeholder — drop a 15s screen recording here) -->
  <section class="container-tight mt-16">
    <div class="mx-auto flex aspect-video max-w-3xl items-center justify-center overflow-hidden rounded-xl border border-line bg-surface">
      <div class="flex flex-col items-center text-center">
        <div class="flex h-14 w-14 items-center justify-center rounded-full border border-line">
          <svg viewBox="0 0 24 24" class="h-6 w-6 text-accent" fill="currentColor" aria-hidden="true">
            <path d="M9 7.5v9l7-4.5-7-4.5Z" />
          </svg>
        </div>
        <p class="mt-4 text-fg">See it in action</p>
        <p class="mono mt-1 text-xs text-fg-3">15-SECOND DEMO COMING SOON</p>
      </div>
    </div>
  </section>

  <!-- HOW -->
  <section class="container-tight mt-24">
    <p class="eyebrow">How it works</p>
    <div class="mt-8 grid gap-px overflow-hidden rounded-xl border border-line bg-line md:grid-cols-3">
      {
        steps.map((step) => (
          <div class="flex items-baseline gap-4 bg-surface p-7">
            <span class="mono text-sm text-accent">{step.n}</span>
            <p class="text-lg text-fg">{step.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- USE CASES -->
  <section class="container-tight mt-24">
    <p class="eyebrow">Who it's for</p>
    <div class="mt-8 grid gap-px overflow-hidden rounded-xl border border-line bg-line md:grid-cols-3">
      {
        useCases.map((u) => (
          <div class="bg-surface p-7">
            <h3 class="text-lg text-fg">{u.role}</h3>
            <p class="mt-3 leading-relaxed text-fg-2">{u.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- DIFFERENTIATOR -->
  <section class="container-tight mt-24">
    <p class="max-w-3xl text-2xl leading-snug text-fg sm:text-[1.7rem]">
      Only SafeScreen blocks harmful images in real time, without sending a single byte off your phone.
    </p>
  </section>

  <!-- CTA -->
  <section id="waitlist" class="container-tight mt-24">
    <div class="card flex flex-col items-start gap-7 p-10 sm:p-14">
      <div>
        <h2 class="text-3xl sm:text-4xl">Be first to protect your screen.</h2>
        <p class="mt-4 text-lg text-fg-2">Launching soon. One email when it's ready.</p>
      </div>
      <WaitlistForm />
    </div>
  </section>
</Layout>
