---
// A stylized phone showing SafeScreen intervening on-device.
// All "content" is abstract gradient art — the product blurs, so the
// hero literally demonstrates the blur. No real imagery, ever.
---

<div class="phone-wrap relative mx-auto w-[280px] sm:w-[310px]">
  <!-- ambient glow -->
  <div
    class="absolute -inset-10 -z-10 rounded-[3rem] opacity-70 blur-3xl"
    style="background: radial-gradient(50% 50% at 50% 30%, color-mix(in oklab, var(--color-safe-500) 38%, transparent), transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative aspect-[9/19] overflow-hidden rounded-[2.6rem] border border-white/10 bg-ink-900 p-2.5 shadow-2xl ring-1 ring-black/40"
  >
    <!-- notch -->
    <div class="absolute left-1/2 top-2 z-30 h-5 w-24 -translate-x-1/2 rounded-full bg-ink-950"></div>

    <div class="relative h-full w-full overflow-hidden rounded-[2.1rem] bg-ink-950">
      <!-- status bar -->
      <div class="flex items-center justify-between px-5 pb-2 pt-3.5 text-[10px] font-500 text-mist-400">
        <span>9:41</span>
        <span class="inline-flex items-center gap-1 text-safe-300">
          <span class="h-1.5 w-1.5 rounded-full bg-safe-400"></span> Protected
        </span>
      </div>

      <!-- feed -->
      <div class="space-y-3 px-3.5">
        <!-- normal post: passes -->
        <div class="rounded-2xl border border-white/5 bg-ink-850 p-2.5">
          <div class="mb-2 flex items-center gap-2">
            <div class="h-6 w-6 rounded-full" style="background: linear-gradient(135deg,#38bdf8,#14cf9b)"></div>
            <div class="h-2 w-20 rounded-full bg-white/10"></div>
            <span class="ml-auto inline-flex items-center gap-1 text-[9px] text-safe-300">
              <svg viewBox="0 0 16 16" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m3.5 8.5 2.6 2.6L12.5 5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Clear
            </span>
          </div>
          <div class="h-20 rounded-xl" style="background: linear-gradient(120deg,#0e1424,#1f2942 60%,#0ea5e9 220%)"></div>
        </div>

        <!-- flagged post: BLURRED intervention -->
        <div class="relative overflow-hidden rounded-2xl border border-warn-400/30 bg-ink-850 p-2.5">
          <div class="mb-2 flex items-center gap-2">
            <div class="h-6 w-6 rounded-full" style="background: linear-gradient(135deg,#f59e0b,#ef4444)"></div>
            <div class="h-2 w-16 rounded-full bg-white/10"></div>
          </div>

          <div class="relative h-28 overflow-hidden rounded-xl">
            <!-- the "harmful" content is abstract + heavily blurred -->
            <div
              class="absolute inset-0 scale-110 blur-2xl"
              style="background: conic-gradient(from 120deg at 50% 50%, #f59e0b, #ef4444, #a855f7, #f59e0b)"
              aria-hidden="true"
            >
            </div>
            <div class="absolute inset-0 bg-ink-950/40"></div>

            <!-- scanning sweep -->
            <div class="scan absolute inset-x-0 h-12" aria-hidden="true"></div>

            <!-- intervention chip -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
              <svg viewBox="0 0 24 24" class="mb-1 h-6 w-6 text-warn-400" fill="none" stroke="currentColor" stroke-width="1.7">
                <path d="M12 3 4 6.2v5.1c0 4.4 3 7.6 8 9.4 5-1.8 8-5 8-9.4V6.2L12 3Z" stroke-linejoin="round"/>
                <path d="M12 9v4M12 16h.01" stroke-linecap="round"/>
              </svg>
              <p class="text-[11px] font-600 text-mist-100">Explicit content blurred</p>
              <p class="mt-1 font-mono text-[9px] text-mist-400">NSFW 72% · AI-gen 8%</p>
            </div>

            <!-- reveal pill -->
            <div class="absolute bottom-2 left-1/2 -translate-x-1/2">
              <span class="glass inline-flex items-center gap-1 rounded-full px-3 py-1 text-[9px] font-500 text-mist-200">
                Tap to reveal
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- on-device banner -->
      <div class="absolute inset-x-3.5 bottom-3.5">
        <div class="glass flex items-center justify-center gap-2 rounded-xl px-3 py-2 text-[10px] text-mist-300">
          <svg viewBox="0 0 16 16" class="h-3.5 w-3.5 text-safe-400" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="7" width="10" height="6.5" rx="1.5"/><path d="M5 7V5a3 3 0 0 1 6 0v2"/>
          </svg>
          Analyzed on-device · <span class="text-safe-300">0 bytes left your phone</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .phone-wrap {
    animation: float 7s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .scan {
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in oklab, var(--color-safe-400) 55%, transparent),
      transparent
    );
    animation: sweep 2.6s var(--ease-out-quint) infinite;
  }
  @keyframes sweep {
    0% { top: -20%; opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { top: 110%; opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .phone-wrap { animation: none; }
    .scan { animation: none; opacity: 0; }
  }
</style>
