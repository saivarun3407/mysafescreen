---
// Flat, static device. No animation, no gradients, no glow. A clean
// representation of the blur intervention. All content is neutral blocks.
---

<div class="mx-auto w-[260px] sm:w-[280px]">
  <div class="rounded-[1.9rem] border border-line bg-surface p-2.5">
    <div class="overflow-hidden rounded-[1.4rem] border border-line-soft bg-bg">
      <!-- top bar -->
      <div class="flex items-center justify-between border-b border-line-soft px-4 py-3 text-[11px]">
        <span class="mono text-fg-3">9:41</span>
        <span class="inline-flex items-center gap-1.5 text-accent">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          <span class="mono text-[10px]">PROTECTED</span>
        </span>
      </div>

      <div class="space-y-3 p-3.5">
        <!-- clear item -->
        <div class="rounded-lg border border-line-soft p-2.5">
          <div class="mb-2 flex items-center gap-2">
            <div class="h-5 w-5 rounded-full bg-surface-2"></div>
            <div class="h-1.5 w-16 rounded-full bg-surface-2"></div>
            <span class="mono ml-auto text-[9px] text-fg-3">CLEAR</span>
          </div>
          <div class="h-16 rounded-md bg-surface-2"></div>
        </div>

        <!-- blurred item -->
        <div class="rounded-lg border border-line p-2.5">
          <div class="mb-2 flex items-center gap-2">
            <div class="h-5 w-5 rounded-full bg-surface-2"></div>
            <div class="h-1.5 w-12 rounded-full bg-surface-2"></div>
          </div>
          <div class="relative h-24 overflow-hidden rounded-md bg-surface-2">
            <div class="absolute inset-0 bg-surface-2"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
              <svg viewBox="0 0 24 24" class="mb-1.5 h-5 w-5 text-warn" fill="none" stroke="currentColor" stroke-width="1.6">
                <path d="M12 3 5 5.6v5c0 4.3 2.9 7.4 7 9 4.1-1.6 7-4.7 7-9v-5L12 3Z" stroke-linejoin="round" />
                <path d="M12 9v4M12 16h.01" stroke-linecap="round" />
              </svg>
              <p class="text-[11px] font-550 text-fg">Content blurred</p>
              <p class="mono mt-1 text-[9px] text-fg-3">NSFW 72%</p>
            </div>
          </div>
        </div>
      </div>

      <div class="border-t border-line-soft px-4 py-2.5 text-center">
        <span class="mono text-[9px] text-fg-3">ANALYZED ON-DEVICE</span>
      </div>
    </div>
  </div>
</div>
