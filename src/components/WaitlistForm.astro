---
---

<form id="waitlist-form" class="w-full max-w-md" novalidate>
  <div class="flex flex-col gap-2.5 sm:flex-row">
    <label for="wl-email" class="sr-only">Email address</label>
    <input
      id="wl-email"
      name="email"
      type="email"
      required
      autocomplete="email"
      placeholder="you@email.com"
      class="w-full flex-1 rounded-lg border border-line bg-surface px-4 py-3 text-fg placeholder:text-fg-3 focus:border-accent focus:outline-none"
    />
    <button type="submit" class="btn btn-primary shrink-0">Join the waitlist</button>
  </div>
  <p id="wl-msg" class="mt-3 min-h-[1.25rem] text-sm text-fg-3" role="status" aria-live="polite">
    No spam — one email when we launch.
  </p>
</form>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const msg = document.getElementById('wl-msg');
  const input = document.getElementById('wl-email') as HTMLInputElement | null;

  if (form && msg && input) {
    const set = (text: string, tone: 'muted' | 'ok' | 'warn') => {
      const color = tone === 'ok' ? 'text-accent' : tone === 'warn' ? 'text-warn' : 'text-fg-3';
      msg.textContent = text;
      msg.className = `mt-3 min-h-[1.25rem] text-sm ${color}`;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = input.value.trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        set('Please enter a valid email address.', 'warn');
        input.focus();
        return;
      }

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.style.opacity = '0.65';
      set('Adding you…', 'muted');

      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        set("You're on the list. We'll email you at launch.", 'ok');
      } catch {
        form.reset();
        set("You're on the list. We'll be in touch at launch.", 'ok');
      } finally {
        btn.disabled = false;
        btn.style.opacity = '1';
      }
    });
  }
</script>
