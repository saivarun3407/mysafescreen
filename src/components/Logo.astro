---
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
---

<a href="/" class={`inline-flex items-center gap-2 ${cls}`} aria-label="SafeScreen home">
  <svg viewBox="0 0 24 24" fill="none" class="h-[1.35rem] w-[1.35rem]" aria-hidden="true">
    <path
      d="M12 3 5 5.6v5c0 4.3 2.9 7.4 7 9 4.1-1.6 7-4.7 7-9v-5L12 3Z"
      stroke="var(--color-accent)"
      stroke-width="1.5"
      stroke-linejoin="round"
    />
    <path d="m9 12 2 2 4-4.5" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  <span class="text-[1.02rem] font-600 tracking-tight text-fg">SafeScreen</span>
</a>
