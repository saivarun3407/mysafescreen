---
interface Props {
  class?: string;
}
const { class: cls = 'h-8 w-auto' } = Astro.props;
---

<a href="/" class={`group inline-flex items-center gap-2.5 ${cls}`} aria-label="SafeScreen home">
  <svg viewBox="0 0 32 32" fill="none" class="h-8 w-8 shrink-0" aria-hidden="true">
    <defs>
      <linearGradient id="ss-shield" x1="4" y1="2" x2="28" y2="30" gradientUnits="userSpaceOnUse">
        <stop stop-color="#6ee7c7" />
        <stop offset="1" stop-color="#0ea5e9" />
      </linearGradient>
    </defs>
    <path
      d="M16 2.6 4.8 6.9v7.7c0 6.6 4.4 11.4 11.2 14.1 6.8-2.7 11.2-7.5 11.2-14.1V6.9L16 2.6Z"
      fill="url(#ss-shield)"
      fill-opacity="0.16"
      stroke="url(#ss-shield)"
      stroke-width="1.6"
    />
    <!-- Eye protected within the shield -->
    <path
      d="M9.5 16c1.7-2.7 4-4 6.5-4s4.8 1.3 6.5 4c-1.7 2.7-4 4-6.5 4s-4.8-1.3-6.5-4Z"
      stroke="url(#ss-shield)"
      stroke-width="1.5"
      stroke-linejoin="round"
    />
    <circle cx="16" cy="16" r="2.1" fill="url(#ss-shield)" />
  </svg>
  <span class="font-display text-[1.15rem] font-600 tracking-tight text-mist-100">
    Safe<span class="text-safe-400">Screen</span>
  </span>
</a>
