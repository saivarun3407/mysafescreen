---
import Logo from './Logo.astro';

const year = new Date().getFullYear();
const cols = [
  {
    title: 'Product',
    links: [
      { href: '/how-it-works', label: 'How it works' },
      { href: '/privacy', label: 'Privacy' },
      { href: '/#waitlist', label: 'Waitlist' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: 'mailto:info@mysafescreen.com', label: 'Contact' },
    ],
  },
];
---

<footer class="mt-32 border-t border-line-soft">
  <div class="container-tight py-14">
    <div class="grid gap-10 sm:grid-cols-[1.6fr_1fr_1fr]">
      <div class="max-w-xs">
        <Logo />
        <p class="mt-4 text-sm leading-relaxed text-fg-3">
          An on-device safety layer for your screen. Harmful and AI-faked imagery, blurred before you see
          it. Nothing ever leaves your phone.
        </p>
        <a href="mailto:info@mysafescreen.com" class="mono mt-5 inline-block text-sm text-fg-2 transition-colors hover:text-accent">
          info@mysafescreen.com
        </a>
      </div>

      {
        cols.map((col) => (
          <div>
            <p class="eyebrow">{col.title}</p>
            <ul class="mt-4 space-y-2.5">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-fg-2 transition-colors hover:text-fg">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-line-soft pt-6 text-xs text-fg-3 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} SafeScreen</p>
      <p>Private by design.</p>
    </div>
  </div>
</footer>
