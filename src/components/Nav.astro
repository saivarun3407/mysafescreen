---
import Logo from './Logo.astro';

const links = [
  { href: '/how-it-works', label: 'How it works' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/about', label: 'About' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path === href + '/';
---

<header class="sticky top-0 z-40 border-b border-line-soft bg-bg/85 backdrop-blur-sm">
  <nav class="container-tight flex h-16 items-center justify-between">
    <Logo />

    <div class="hidden items-center gap-7 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'text-sm transition-colors',
              isActive(l.href) ? 'text-fg' : 'text-fg-2 hover:text-fg',
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <a href="/#waitlist" class="btn btn-primary text-sm">Join the waitlist</a>
  </nav>
</header>
