---
import Logo from './Logo.astro';

const links = [
  { href: '/how-it-works', label: 'How it works' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/about', label: 'About' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path === href + '/';
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-40 transition-all duration-300"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3.5 sm:px-8">
    <Logo />

    <div class="hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-500 transition-colors',
              isActive(l.href) ? 'text-mist-100' : 'text-mist-400 hover:text-mist-100',
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2.5">
      <a
        href="/#waitlist"
        class="btn-primary hidden rounded-full px-5 py-2.5 text-sm sm:inline-flex"
      >
        Join the waitlist
      </a>
      <a
        href="/#waitlist"
        class="btn-primary rounded-full px-4 py-2 text-sm sm:hidden"
      >
        Join
      </a>
    </div>
  </nav>
</header>

<style>
  #site-nav.nav-scrolled nav {
    background: color-mix(in oklab, var(--color-ink-900) 72%, transparent);
    border: 1px solid color-mix(in oklab, #fff 7%, transparent);
    border-radius: 999px;
    backdrop-filter: blur(16px);
    margin-top: 0.5rem;
    box-shadow: 0 12px 40px -24px rgba(0, 0, 0, 0.8);
  }
  #site-nav {
    --pad: 0;
  }
  #site-nav.nav-scrolled {
    padding-inline: 0.75rem;
  }
</style>
